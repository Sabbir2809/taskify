# ----------------------
# Server
# ----------------------
PORT=5000
NODE_ENV=development

# ----------------------
# Database (PostgreSQL)
# ----------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskify
POSTGRES_PORT=5432
# Prisma database URL
DATABASE_URL="postgresql://postgres:postgres@taskify-postgres:5432/taskify?schema=public"

# ----------------------
# Auth
# ----------------------
JWT_SECRET=taskify
JWT_EXPIRES_IN=7d

# ----------------------
# Frontend (CORS)
# ----------------------
FRONTEND_URL=http://localhost:5173